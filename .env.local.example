# Anthropic
ANTHROPIC_API_KEY=             # Required for AI chat agent and scheduled scans

# Database
DATABASE_URL=                  # PostgreSQL connection string (e.g., postgres://user:pass@localhost:5432/permitiq)

# Redis (optional for MVP)
REDIS_URL=                     # Redis connection string

# File Storage (Cloudflare R2)
R2_ACCOUNT_ID=                 # Cloudflare account ID
R2_ACCESS_KEY_ID=              # R2 access key
R2_SECRET_ACCESS_KEY=          # R2 secret key
R2_BUCKET_NAME=permitiq-docs   # R2 bucket name

# Notifications
SENDGRID_API_KEY=              # Email digest and follow-up drafts
SLACK_BOT_TOKEN=               # Slack notifications
SLACK_SIGNING_SECRET=          # Slack signing secret

# Auth
JWT_SECRET=                    # Minimum 32 chars
JWT_EXPIRY=24h                 # Token expiry duration

# Integrations (Phase 3)
PROCORE_CLIENT_ID=             # Procore OAuth client ID
PROCORE_CLIENT_SECRET=         # Procore OAuth client secret

# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000
AGENT_SCHEDULE="0 9 * * 2,5"   # Cron: 9AM Tuesday and Friday
