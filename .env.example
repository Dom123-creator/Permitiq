# PermitIQ Environment Variables
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# ─── Anthropic (AI Chat Agent + Scheduled Scans) ───────────────────
ANTHROPIC_API_KEY=              # Required — get from https://console.anthropic.com

# ─── Database (PostgreSQL via Neon) ────────────────────────────────
DATABASE_URL=                   # Required — Neon connection string
                                # Format: postgresql://user:pass@host/db?sslmode=require

# ─── File Storage (Cloudflare R2) ──────────────────────────────────
R2_ACCOUNT_ID=                  # Get from Cloudflare dashboard → R2 → Overview
R2_ACCESS_KEY_ID=               # R2 → Manage R2 API Tokens → Create API token
R2_SECRET_ACCESS_KEY=           # Same as above
R2_BUCKET_NAME=permitiq-docs    # Create bucket named "permitiq-docs" in R2

# ─── Email (SendGrid) ─────────────────────────────────────────────
SENDGRID_API_KEY=               # https://app.sendgrid.com → Settings → API Keys
SENDGRID_FROM_EMAIL=noreply@permitiq.app   # Must be verified sender in SendGrid
SENDGRID_FROM_NAME=PermitIQ

# ─── Slack Notifications ──────────────────────────────────────────
SLACK_BOT_TOKEN=                # Slack App → OAuth & Permissions → Bot Token
SLACK_SIGNING_SECRET=           # Slack App → Basic Information → Signing Secret

# ─── Telegram Bot (Proactive Agent Notifications) ─────────────────
TELEGRAM_BOT_TOKEN=             # Message @BotFather → /newbot → copy token
TELEGRAM_WEBHOOK_SECRET=        # Any random string (1-256 chars), used to verify webhook

# ─── SMS (Twilio) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=             # https://console.twilio.com → Account SID
TWILIO_AUTH_TOKEN=              # Same page → Auth Token
TWILIO_PHONE_NUMBER=            # Buy a number in Twilio → format: +1XXXXXXXXXX

# ─── Auth (NextAuth v5) ───────────────────────────────────────────
AUTH_SECRET=                    # Required — run: openssl rand -base64 32
AUTH_URL=http://localhost:3000  # Your app URL (change in production)
NEXTAUTH_SECRET=                # Same as AUTH_SECRET (legacy compat)
NEXTAUTH_URL=http://localhost:3000

# ─── SSO: Google OAuth ────────────────────────────────────────────
# Setup: https://console.cloud.google.com → APIs & Services → Credentials
# Create OAuth 2.0 Client ID, set redirect URI to: {AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── SSO: Microsoft Entra ID (Azure AD) ───────────────────────────
# Setup: https://entra.microsoft.com → App registrations → New registration
# Set redirect URI to: {AUTH_URL}/api/auth/callback/azure-ad
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common       # Use "common" for multi-tenant, or your tenant ID

# ─── Procore Integration ──────────────────────────────────────────
PROCORE_REDIRECT_URI=http://localhost:3000/api/integrations/procore/callback

# ─── Zapier Webhook ───────────────────────────────────────────────
ZAPIER_WEBHOOK_SECRET=          # Any random string for webhook verification

# ─── Vercel Cron ──────────────────────────────────────────────────
CRON_SECRET=                    # Secret for POST /api/agent/scan from Vercel Cron

# ─── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000
AGENT_SCHEDULE="0 9 * * 2,5"   # Cron: 9AM Tuesday and Friday
